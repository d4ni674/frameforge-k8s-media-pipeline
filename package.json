{
  "name": "frameforge-k8s-media-pipeline",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "test": "npm run -ws test",
    "test:e2e": "cd e2e && npm test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:api": "npm run --workspace @frameforge/api start:dev",
    "dev:worker": "npm run --workspace @frameforge/worker dev"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
